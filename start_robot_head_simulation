#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DROIDCAM_URL="${DROIDCAM_URL:-http://192.168.101.101:4747/video}"

return_or_exit() {
    local status="$1"
    if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
        return "$status"
    fi
    exit "$status"
}

is_wsl() {
    [[ -n "${WSL_DISTRO_NAME:-}" ]] || uname -r | grep -qi microsoft
}

have_windows_terminal() {
    command -v powershell.exe >/dev/null 2>&1 && cmd.exe /c where wt.exe >/dev/null 2>&1
}

have_gui_terminal() {
    command -v gnome-terminal >/dev/null 2>&1 \
        && [[ -n "${DISPLAY:-}" ]] \
        && [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]] \
        && command -v gdbus >/dev/null 2>&1 \
        && gdbus introspect \
            --session \
            --dest org.gnome.Terminal \
            --object-path /org/gnome/Terminal/Factory0 \
            >/dev/null 2>&1
}

launch_in_windows_terminal_windows() {
    local title
    local cmd
    local shell_cmd
    local root_dir="$ROOT_DIR"
    local distro_name="${WSL_DISTRO_NAME:-Ubuntu}"
    local ps_command

    read -r -d '' ps_command <<'EOF' || true
$title = $env:SOP_TITLE
$cmd = $env:SOP_CMD
$root = $env:SOP_ROOT
$distro = $env:SOP_DISTRO
# `--` stops wt.exe from parsing WSL's `-d/--cd` flags as terminal options.
& wt.exe -w new new-tab --title $title -- wsl.exe --distribution $distro --cd $root bash -lc $cmd | Out-Null
EOF

    for title in "$@"; do
        cmd="${COMMANDS[$title]}"
        printf -v shell_cmd 'cd %q && %s; exec bash' "$ROOT_DIR" "$cmd"
        env \
            SOP_TITLE="$title" \
            SOP_CMD="$shell_cmd" \
            SOP_ROOT="$root_dir" \
            SOP_DISTRO="$distro_name" \
            powershell.exe -NoProfile -Command "$ps_command" >/dev/null 2>&1
        sleep 0.2
    done

    echo "Launched robot head simulation in separate Windows Terminal windows."
}

window_geometry_for_index() {
    local index="$1"
    local geometries=(
        "100x28+20+20"
        "100x28+860+20"
        "100x28+20+360"
        "100x28+860+360"
        "100x28+120+80"
        "100x28+960+80"
        "100x28+220+140"
        "100x28+1060+140"
    )

    if (( index < ${#geometries[@]} )); then
        printf '%s\n' "${geometries[$index]}"
    else
        printf '%s\n' "100x28+120+80"
    fi
}

launch_in_gnome_terminal_windows() {
    local index=0
    local title
    local cmd
    local shell_cmd
    local geometry

    for title in "$@"; do
        cmd="${COMMANDS[$title]}"
        printf -v shell_cmd 'cd %q && %s; exec bash' "$ROOT_DIR" "$cmd"
        geometry="$(window_geometry_for_index "$index")"
        gnome-terminal --geometry="$geometry" --window --title="$title" -- bash -lc "$shell_cmd"
        sleep 0.2
        index=$((index + 1))
    done

    echo "Launched robot head simulation in separate GNOME Terminal windows."
}

declare -A COMMANDS=(
    ["Robot"]="bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh launch robot robot.fake.launch.py use_rviz:=false"
    ["RViz"]="sleep 3 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run rviz2 rviz2 -d src/inmoov_description/config/inmoov.rviz"
    ["Face Tracker"]="sleep 5 && (bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run rqt_image_view rqt_image_view /face_tracker/image_face & bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh launch face_tracker face_tracker.test.launch.py camera_source:='$DROIDCAM_URL')"
    ["Movement"]="sleep 5 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run face_tracker_movement face_tracker_movement_node --ros-args -p simulation:=true"
    ["Full Demo"]="sleep 5 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run full_demo full_demo_node"
    ["Voice Chatbot"]="sleep 5 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh launch voice_chatbot_ros voice_chatbot.launch.py"
    ["Chatbot App"]="sleep 7 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run voice_chatbot_ros voice_chatbot_ros_app"
    ["Jaw Movement"]="sleep 5 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run jaw_movement jaw_movement_node"
)

TITLES=(
    "Robot"
    "RViz"
    "Face Tracker"
    "Movement"
    "Full Demo"
    "Voice Chatbot"
    "Chatbot App"
    "Jaw Movement"
)

if have_gui_terminal; then
    if launch_in_gnome_terminal_windows "${TITLES[@]}"; then
        return_or_exit 0
    fi
    echo "GNOME Terminal could not be started." >&2
fi

if is_wsl && have_windows_terminal; then
    if launch_in_windows_terminal_windows "${TITLES[@]}"; then
        return_or_exit 0
    fi
    echo "Windows Terminal could not be started." >&2
fi

echo "No usable graphical terminal session found. Run these commands manually:" >&2
for title in "${TITLES[@]}"; do
    echo "  $title: ${COMMANDS[$title]}" >&2
done
return_or_exit 1
