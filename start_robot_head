#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DROIDCAM_URL="${DROIDCAM_URL:-http://192.168.101.101:4747/video}"
SESSION_BASE="${SOP_ROBOT_SESSION_NAME:-sop-robot-head}"

return_or_exit() {
    local status="$1"
    if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
        return "$status"
    fi
    exit "$status"
}

have_gui_terminal() {
    command -v gnome-terminal >/dev/null 2>&1 \
        && [[ -n "${DISPLAY:-}" ]] \
        && [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]] \
        && command -v gdbus >/dev/null 2>&1 \
        && gdbus introspect \
            --session \
            --dest org.gnome.Terminal \
            --object-path /org/gnome/Terminal/Factory0 \
            >/dev/null 2>&1
}

unique_tmux_session() {
    local session="$1"
    local suffix=1

    while tmux has-session -t "$session" 2>/dev/null; do
        session="${1}-${suffix}"
        suffix=$((suffix + 1))
    done

    printf '%s\n' "$session"
}

launch_in_gnome_terminal() {
    local titles=("$@")
    local args=(--window)
    local title
    local cmd
    local shell_cmd

    for title in "${titles[@]}"; do
        cmd="${COMMANDS[$title]}"
        printf -v shell_cmd 'cd %q && %s; exec bash' "$ROOT_DIR" "$cmd"
        args+=(--tab --title="$title" -- bash -lc "$shell_cmd")
    done

    gnome-terminal "${args[@]}"
    echo "Launched robot head bring-up in GNOME Terminal tabs."
}

launch_in_tmux() {
    local session
    local first_title="$1"
    local title
    local cmd
    local shell_cmd

    session="$(unique_tmux_session "$SESSION_BASE")"

    cmd="${COMMANDS[$first_title]}"
    printf -v shell_cmd 'cd %q && %s; exec bash' "$ROOT_DIR" "$cmd"
    tmux new-session -d -s "$session" -n "$first_title" "$shell_cmd"

    shift
    for title in "$@"; do
        cmd="${COMMANDS[$title]}"
        printf -v shell_cmd 'cd %q && %s; exec bash' "$ROOT_DIR" "$cmd"
        tmux new-window -t "${session}:" -n "$title" "$shell_cmd"
    done

    echo "GNOME Terminal is unavailable in this session."
    echo "Launched robot head bring-up in tmux session '$session'."
    echo "Attach with: tmux attach -t $session"
}

declare -A COMMANDS=(
    ["Robot"]="bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh launch robot robot.launch.py robot_parts:=head"
    ["Face Tracker"]="sleep 5 && (bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run rqt_image_view rqt_image_view /face_tracker/image_face & bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh launch face_tracker face_tracker.test.launch.py camera_source:='$DROIDCAM_URL')"
    ["Movement"]="sleep 5 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run face_tracker_movement face_tracker_movement_node"
    ["Full Demo"]="sleep 5 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run full_demo full_demo_node"
    ["Hand Gestures"]="sleep 5 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run hand_gestures hand_gestures_node"
    ["Voice Chatbot"]="sleep 5 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh launch voice_chatbot_ros voice_chatbot.launch.py"
    ["Jaw Movement"]="sleep 5 && bash src/voice_chatbot_ros/tools/ros_exec_pixi.sh run jaw_movement jaw_movement_node"
    ["Arms Client"]="sleep 5 && pixi run python client/unified_arms_client.py"
)

TITLES=(
    "Robot"
    "Face Tracker"
    "Movement"
    "Full Demo"
    "Hand Gestures"
    "Voice Chatbot"
    "Jaw Movement"
    "Arms Client"
)

if have_gui_terminal; then
    if launch_in_gnome_terminal "${TITLES[@]}"; then
        return_or_exit 0
    fi
    echo "Falling back to tmux because GNOME Terminal could not be started." >&2
fi

if command -v tmux >/dev/null 2>&1; then
    launch_in_tmux "${TITLES[@]}"
else
    echo "No usable multi-process launcher found. Run these commands manually:" >&2
    for title in "${TITLES[@]}"; do
        echo "  $title: ${COMMANDS[$title]}" >&2
    done
    return_or_exit 1
fi
